  <diagram name="Activity Flow - placeOrder" id="activity-diagram">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <!-- START -->
        <mxCell id="start" value="" style="ellipse;aspect=fixed;fillColor=#10B981;strokeColor=#10B981;" vertex="1" parent="1">
          <mxGeometry x="360" y="40" width="30" height="30" as="geometry" />
        </mxCell>
        <!-- POST /orders received -->
        <mxCell id="a0" value="POST /orders received" style="rounded=1;fillColor=#1E293B;strokeColor=#475569;fontColor=#E2E8F0;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="270" y="100" width="210" height="40" as="geometry" />
        </mxCell>
        <mxCell id="e_start_a0" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#475569;" edge="1" source="start" target="a0" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- AuthMiddleware -->
        <mxCell id="a1" value="AuthMiddleware&#xa;Extract userId from X-User-Id header" style="rounded=1;fillColor=#451A03;strokeColor=#F59E0B;fontColor=#F59E0B;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="270" y="180" width="210" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e0_1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#475569;" edge="1" source="a0" target="a1" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Auth Decision -->
        <mxCell id="d1" value="userId present?" style="rhombus;fillColor=#451A03;strokeColor=#F59E0B;fontColor=#F59E0B;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="300" y="265" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e1_d1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#F59E0B;" edge="1" source="a1" target="d1" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- 401 -->
        <mxCell id="r401" value="401 Unauthorized" style="rounded=1;fillColor=#450A0A;strokeColor=#EF4444;fontColor=#EF4444;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="520" y="275" width="160" height="40" as="geometry" />
        </mxCell>
        <mxCell id="e_d1_401" style="strokeColor=#EF4444;" edge="1" source="d1" target="r401" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_d1_401_label" value="No" style="edgeLabel;fontSize=10;fontColor=#EF4444;" vertex="1" connectable="0" parent="e_d1_401">
          <mxGeometry relative="0.5" as="geometry" />
        </mxCell>
        <!-- IdempotencyMiddleware -->
        <mxCell id="a2" value="IdempotencyMiddleware&#xa;Check X-Idempotency-Key in DB" style="rounded=1;fillColor=#451A03;strokeColor=#F59E0B;fontColor=#F59E0B;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="270" y="360" width="210" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e_d1_a2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#10B981;" edge="1" source="d1" target="a2" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_d1_a2_label" value="Yes" style="edgeLabel;fontSize=10;fontColor=#10B981;" vertex="1" connectable="0" parent="e_d1_a2">
          <mxGeometry relative="0.5" as="geometry" />
        </mxCell>
        <!-- Idempotency Decision -->
